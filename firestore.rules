rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profile Access
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Global site configuration and public content
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /pages/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /blogPosts/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /courseModules/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /resources/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /generatedVideos/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{docId} { allow read: if true; allow write: if isAdmin(); }

    // Operator Registry - Users can see their own
    match /operators/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // Program Content - Accessible by any logged in user
    match /programContent/{document=**} {
      allow read: if request.auth != null;
    }

    // Paid Content - Accessible by paid members or admins
    match /paidContent/{document=**} {
      allow read: if isPaid() || isAdmin();
    }

    // Public Intake
    match /admissionInquiries/{id} { allow create: if true; allow read, write: if isAdmin(); }
    match /readinessAssessments/{id} { allow create: if true; allow read, write: if isAdmin(); }
    match /leadMagnets/{id} { allow create: if true; allow read, write: if isAdmin(); }
    match /formSubmissions/{id} { allow create: if true; allow read, write: if isAdmin(); }
    match /contacts/{id} { allow create: if true; allow read, write: if isAdmin(); }

    // Helper Functions
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isPaid() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'paid';
    }
  }
}
