# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub

# MongoDB Atlas connection string (get from atlas.mongodb.com)
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Name of your MongoDB database
DB_NAME=launchpath_prod

# Comma-separated list of allowed frontend origins
# Set this to your Vercel production URL after deploying
CORS_ORIGINS=https://launchpathedu.com

# Your production frontend URL (used in transactional email links)
FRONTEND_URL=https://launchpathedu.com

# Emergent Auth API URL (do not change unless instructed)
EMERGENT_AUTH_URL=https://demobackend.emergentagent.com/auth/v1/env/oauth/session-data

# MailerLite API token for lead capture
MAILERLITE_API_TOKEN=

# Stripe API key (use live key for production, test key for staging)
STRIPE_API_KEY=sk_live_...

# Stripe webhook secret (from Stripe dashboard -> Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# MailerSend transactional email
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=noreply@launchpathedu.com
MAILERSEND_FROM_NAME=LaunchPath
